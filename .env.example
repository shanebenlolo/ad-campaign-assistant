# Google Ads API credentials
# Required for both plan and apply.
GOOGLE_ADS_DEVELOPER_TOKEN=your-google-ads-developer-token
GOOGLE_ADS_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_ADS_REFRESH_TOKEN=your-oauth-refresh-token

# Customer IDs should be numeric, with or without dashes.
GOOGLE_ADS_CUSTOMER_ID=1234567890

# Required only when using a manager account to access a client account.
# Use the manager account customer ID, not the client account ID.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Google Ads API version used by the Python client.
GOOGLE_ADS_API_VERSION=v24
GOOGLE_ADS_USE_PROTO_PLUS=true

# Anthropic API credentials and model configuration
# Required for plan.
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=8000
ANTHROPIC_TEMPERATURE=0.2

# Soft cap for the normalized JSON sent to Anthropic.
# If exceeded, lower-priority rows are trimmed before planning.
ANTHROPIC_MAX_INPUT_CHARS=180000

# Reporting defaults
# Use a Google Ads date range constant such as LAST_7_DAYS, LAST_30_DAYS,
# THIS_MONTH, LAST_MONTH, or use YYYY-MM-DD,YYYY-MM-DD on the CLI.
REPORT_DATE_RANGE=LAST_30_DAYS

# Keyword Planner defaults
# 2840 = United States, 2124 = Canada, 2826 = United Kingdom.
KEYWORD_PLANNER_LOCATION_IDS=2840
# 1000 = English.
KEYWORD_PLANNER_LANGUAGE_ID=1000
